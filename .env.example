# ─────────────────────────────────────────────────────────────────────────────
# Domus — global environment template.
# Copy to `apps/api/.env` for local dev (`cp .env.example apps/api/.env`),
# or export these in your shell / inject via docker-compose.
# Every value has a safe default in backend/core/config.py; override what you need.
#
# Single source of truth: change a port (or PUBLIC_HOST) ONCE here and Docker
# Compose rebuilds every URL that depends on it (DB, Redis, CORS, the browser's
# API URL). A plain .env can't expand ${VARS}, so those URLs are composed in
# docker-compose.yml — don't re-add hardcoded host:port strings for the Docker path.
# ─────────────────────────────────────────────────────────────────────────────

# --- Ports (Docker host mappings — everything below derives from these) ---
WEB_PORT=3000
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
PGADMIN_PORT=5050

# Host that OTHER devices (phones, tablets, the desktop app) use to reach this
# machine. `localhost` = same machine only. Set your LAN IP (e.g. 192.168.1.50)
# so other devices can reach the web UI + API. Used to derive the default API URL
# and the allowed CORS origins.
PUBLIC_HOST=localhost

# Public URL the BROWSER uses to reach the API. Blank = auto (http://PUBLIC_HOST:
# API_PORT), fine for localhost/LAN. Set this for a reverse proxy / external
# domain, e.g. https://api.example.com — it must be reachable from the browser.
# NEXT_PUBLIC_*, baked at BUILD time: rebuild web after changing (compose up --build).
PUBLIC_API_URL=

# Extra browser origins allowed through CORS (comma-separated). localhost and
# PUBLIC_HOST are always allowed; add your public web URL, e.g.
# https://domus.example.com
EXTRA_CORS_ORIGINS=

# --- App ---
APP_NAME=Domus API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Database / Redis (credentials only — compose builds the URLs from the ports) ---
POSTGRES_USER=domus
POSTGRES_PASSWORD=domus
POSTGRES_DB=domus

# --- Auth / JWT ---
# CHANGE THESE IN PRODUCTION. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Encryption at rest (integration credentials) ---
# CHANGE THIS. Distinct from JWT_SECRET. Rotating it makes stored secrets unreadable.
ENCRYPTION_KEY=change-me-too

# --- Local device discovery ---
# LAN subnet(s) the "scan" button sweeps to find local devices (Tapo/Kasa, …).
# REQUIRED in Docker: UDP broadcast can't cross the bridge network, so set this
# to your LAN, e.g. 192.168.1.0/24 (match it to PUBLIC_HOST's network). Comma-
# separate multiple. Leave blank if the API runs on the LAN/host network.
DISCOVERY_SUBNETS=

# --- Rate limiting (auth endpoints) ---
AUTH_RATE_LIMIT=10/minute

# --- MQTT ---
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# --- Web Frontend ---
# "false" connects to the real API; anything else uses the in-memory mock.
NEXT_PUBLIC_USE_MOCK_API=false
# Optional: override the WebSocket origin (defaults to API URL with http->ws).
# NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─────────────────────────────────────────────────────────────────────────────
# Local (non-Docker) dev ONLY — `bun run dev:api` reads these directly.
# Docker ignores them (compose injects the container URLs). If you run the API
# outside Docker, keep these ports in sync with POSTGRES_PORT/REDIS_PORT above.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://domus:domus@localhost:5432/domus
REDIS_URL=redis://localhost:6379/0
