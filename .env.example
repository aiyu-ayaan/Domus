# ─────────────────────────────────────────────────────────────────────────────
# Domus — global environment template.
# Copy to `apps/api/.env` for local dev (`cp .env.example apps/api/.env`),
# or export these in your shell / inject via docker-compose.
# Every value has a safe default in backend/core/config.py; override what you need.
# ─────────────────────────────────────────────────────────────────────────────

# --- Ports (Docker host mappings — change these to use non-default ports) ---
WEB_PORT=3000
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
PGADMIN_PORT=5050

# --- App ---
APP_NAME=Domus API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Database (async psycopg3 driver) ---
# Default for local dev — Docker compose overrides this with the correct
# internal hostname + port (uses ${POSTGRES_PORT:-5432}).
DATABASE_URL=postgresql+psycopg://domus:domus@localhost:5432/domus

# --- Redis (cache, event bus, queue) ---
# Default for local dev — Docker compose overrides this with the correct
# internal hostname + port (uses ${REDIS_PORT:-6379}).
REDIS_URL=redis://localhost:6379/0

# --- Auth / JWT ---
# CHANGE THESE IN PRODUCTION. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Encryption at rest (integration credentials) ---
# CHANGE THIS. Distinct from JWT_SECRET. Rotating it makes stored secrets unreadable.
ENCRYPTION_KEY=change-me-too

# --- CORS (JSON array) ---
# NOTE: If you change WEB_PORT above, update the port here too.
CORS_ORIGINS=["http://localhost:3000"]

# --- Rate limiting (auth endpoints) ---
AUTH_RATE_LIMIT=10/minute

# --- MQTT ---
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# --- Web Frontend (NEXT_PUBLIC_* are inlined into the browser bundle at build) ---
# apps/web reads these from this root file via next.config.mjs, so the web,
# mobile, and desktop clients share one env. Point the API URL at your
# self-hosted backend to control devices from anywhere.
# NOTE: If you change API_PORT above, update the port here too.
NEXT_PUBLIC_API_URL=http://localhost:8000
# "false" connects to the real API; anything else uses the in-memory mock.
NEXT_PUBLIC_USE_MOCK_API=false
# Optional: override the WebSocket origin (defaults to API URL with http->ws).
# NOTE: If you change API_PORT above, update the port here too.
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
