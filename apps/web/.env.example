# ─────────────────────────────────────────────────────────────────────────────
# Domus Web — frontend environment.
# Copy to `.env.local` for local dev: `cp .env.example .env.local`
# All vars are NEXT_PUBLIC_* so they are inlined into the browser bundle at build.
# ─────────────────────────────────────────────────────────────────────────────

# Use the in-memory mock backend instead of the real API.
# "false" connects to the FastAPI backend; anything else (or unset) = mock mode.
NEXT_PUBLIC_USE_MOCK_API=false

# FastAPI base URL. The client appends /api/v1/* for REST and /ws for the socket.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: override the WebSocket origin. Defaults to NEXT_PUBLIC_API_URL with
# http→ws. Set only if the socket lives on a different host.
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
