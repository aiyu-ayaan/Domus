{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "plugins": [
            {
                "name": "next"
            }
        ],
        "jsx": "preserve",
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ],
            "@domus/shared-types": [
                "../../packages/shared-types/src"
            ]
        }
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}