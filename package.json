{
  "name": "domus",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "bun run scripts/run-dev.ts 3000 bun --cwd apps/web dev",
    "dev:api": "bun run scripts/run-dev.ts 8000 bun --cwd apps/api dev",
    "build": "bun --filter \"*\" build",
    "build:web": "bun --filter @domus/web build",
    "build:native": "bun --cwd apps/web build:native",
    "android": "bun --cwd apps/web android",
    "ios": "bun --cwd apps/web ios",
    "desktop": "bun --cwd apps/web desktop",
    "start": "bun --cwd apps/web start",
    "prod": "docker-compose -f docker-compose.yml up -d",
    "prod:stop": "docker-compose -f docker-compose.yml down",
    "release:web": "docker compose -f docker-compose.release.yml run --rm --build web",
    "release:android": "docker compose -f docker-compose.release.yml run --rm --build android",
    "release:desktop": "docker compose -f docker-compose.release.yml run --rm --build desktop",
    "release": "bun run release:web && bun run release:android && bun run release:desktop",
    "lint": "bun --filter \"*\" lint",
    "format": "prettier . --write",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.6",
    "prettier": "^3.3.3"
  }
}
