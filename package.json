{
    "name": "domus",
    "private": true,
    "version": "0.1.0",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev:web": "npm run dev --workspace @domus/web",
        "dev:api": "npm run dev --workspace @domus/api",
        "build": "npm run build --workspaces",
        "lint": "npm run lint --workspaces",
        "format": "prettier . --write",
        "prepare": "husky"
    },
    "devDependencies": {
        "husky": "^9.1.6",
        "prettier": "^3.3.3"
    }
}